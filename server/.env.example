PORT=5000
CLIENT_URL=http://localhost:5173

# MongoDB
MONGODB_URI=mongodb+srv://<db_user>:<db_password>@<cluster-url>/<db_name>?retryWrites=true&w=majority
MONGODB_FALLBACK_URI=
MONGODB_DB_NAME=tmusic

# JWT
JWT_SECRET=change-this-secret
JWT_EXPIRES_IN=7d

# Optional bootstrap admin account for /admin/login
ADMIN_DISPLAY_NAME=TMusic Admin
ADMIN_EMAIL=admin@tmusic.local
ADMIN_PASSWORD=change-this-admin-password

# Frontend callback sau khi OAuth backend xá»­ lĂ½ xong
AUTH_CLIENT_CALLBACK_URL=http://localhost:5173/auth/callback

# Google OAuth
# Láº¥y á»Ÿ Google Cloud Console > APIs & Services > Credentials > OAuth client ID
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/oauth/google/callback

# Facebook OAuth
# Láº¥y á»Ÿ Meta for Developers > App Settings > Basic
FACEBOOK_CLIENT_ID=your-facebook-app-id
FACEBOOK_CLIENT_SECRET=your-facebook-app-secret
FACEBOOK_CALLBACK_URL=http://localhost:5000/api/auth/oauth/facebook/callback

# Apple OAuth
# APPLE_CLIENT_ID = Services ID identifier, vĂ­ dá»¥ com.tmusic.web
# APPLE_PRIVATE_KEY = ná»™i dung file .p8 trĂªn 1 dĂ²ng, xuá»‘ng dĂ²ng báº±ng \n
APPLE_CLIENT_ID=com.tmusic.web
APPLE_TEAM_ID=your-apple-team-id
APPLE_KEY_ID=your-apple-key-id
APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_CONTENT\n-----END PRIVATE KEY-----"
APPLE_CALLBACK_URL=http://localhost:5000/api/auth/oauth/apple/callback

# Cloudinary image uploads for admin dashboard
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_FOLDER=tmusic

# Audio processing
FFMPEG_PATH=ffmpeg
TRACK_UPLOAD_MAX_MB=100
