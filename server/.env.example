PORT=5000
CLIENT_URL=http://localhost:5173

# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/tmusic
MONGODB_FALLBACK_URI=
MONGODB_DB_NAME=tmusic

# JWT
JWT_SECRET=change-this-secret
JWT_EXPIRES_IN=7d

# Frontend callback sau khi OAuth backend xử lý xong
AUTH_CLIENT_CALLBACK_URL=http://localhost:5173/auth/callback

# Google OAuth
# Lấy ở Google Cloud Console > APIs & Services > Credentials > OAuth client ID
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/oauth/google/callback

# Facebook OAuth
# Lấy ở Meta for Developers > App Settings > Basic
FACEBOOK_CLIENT_ID=your-facebook-app-id
FACEBOOK_CLIENT_SECRET=your-facebook-app-secret
FACEBOOK_CALLBACK_URL=http://localhost:5000/api/auth/oauth/facebook/callback

# Apple OAuth
# APPLE_CLIENT_ID = Services ID identifier, ví dụ com.tmusic.web
# APPLE_PRIVATE_KEY = nội dung file .p8 trên 1 dòng, xuống dòng bằng \n
APPLE_CLIENT_ID=com.tmusic.web
APPLE_TEAM_ID=your-apple-team-id
APPLE_KEY_ID=your-apple-key-id
APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_CONTENT\n-----END PRIVATE KEY-----"
APPLE_CALLBACK_URL=http://localhost:5000/api/auth/oauth/apple/callback

# SMS OTP thật qua Twilio. Bỏ trống nếu chỉ test local bằng devCode.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
